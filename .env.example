# ============================================================
# Event Weather Dashboard - Configuração de Ambiente
# cp .env.example .env  e preencha os valores
# ============================================================

# --- OpenWeather API ---
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Banco de Dados ---
# Escolha o driver: mysql | pgsql
DB_CONNECTION=mysql

# Host/porta sao opcionais. Se nao informar, o backend usa o padrao do driver.
# DB_HOST=mysql
# DB_PORT=3306

DB_NAME=event_weather
DB_USER=weather_user
DB_PASSWORD=weather_pass
DB_ROOT_PASSWORD=rootpassword

# --- Aplicação ---
APP_ENV=development
