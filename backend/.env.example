APP_NAME="inEvent"
APP_ENV=development
APP_KEY=base64:GERE_COM_php_artisan_key:generate
APP_DEBUG=true
APP_URL=http://localhost

# ── Banco de Dados ─────────────────────────────────────────────────────────
# Troque apenas DB_CONNECTION para alternar entre MySQL e Postgres.
# DB_HOST e DB_PORT sao opcionais; se omitidos, o backend usa o padrao do driver.

# MySQL (padrão via Docker Compose)
DB_CONNECTION=mysql
#DB_HOST=mysql
#DB_PORT=3306

# PostgreSQL (alternativa)
#DB_CONNECTION=pgsql
#DB_HOST=postgres
#DB_PORT=5432

DB_DATABASE=event_weather
DB_USERNAME=weather_user
DB_PASSWORD=weather_pass
# ──────────────────────────────────────────────────────────────────────────

OPENWEATHER_API_KEY=sua_chave_aqui

CACHE_DRIVER=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PORT=6379
